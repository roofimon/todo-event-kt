<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Dedicated rolling file for domain events. -->
    <appender name="DOMAIN_EVENTS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/domain-events.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/domain-events.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern>
        </encoder>
    </appender>

    <!-- additivity=false: domain events go ONLY to the file, not the console. -->
    <logger name="domain-events" level="INFO" additivity="false">
        <appender-ref ref="DOMAIN_EVENTS"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
